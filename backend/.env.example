# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Base de donnees PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=luxury_car_rental
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=change_this_super_secret_key_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_this_other_secret_key_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Redis (bonus - cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# API externe - ExchangeRate API (https://www.exchangerate-api.com/)
# Cle gratuite a recuperer sur exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6

# API externe - OpenWeather (https://openweathermap.org/api)
# Cle gratuite a recuperer sur openweathermap.org
OPENWEATHER_API_KEY=your_openweather_api_key

# Frontend (pour CORS)
FRONTEND_URL=http://localhost:5173
